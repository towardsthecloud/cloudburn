{
  "name": "@cloudburn/cli",
  "version": "0.1.0",
  "description": "Cloudburn CLI for cloud cost optimization",
  "type": "module",
  "bin": {
    "cloudburn": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@cloudburn/sdk": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "Apache-2.0"
}
