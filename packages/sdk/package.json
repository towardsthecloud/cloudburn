{
  "name": "@cloudburn/sdk",
  "version": "0.14.0",
  "description": "Cloudburn SDK for cloud cost optimization",
  "homepage": "https://cloudburn.io/docs",
  "bugs": {
    "url": "https://github.com/towardsthecloud/cloudburn/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/towardsthecloud/cloudburn.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@aws-sdk/client-cloudtrail": "^3.1003.0",
    "@aws-sdk/client-cloudwatch": "^3.1003.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1003.0",
    "@aws-sdk/client-ec2": "^3.1003.0",
    "@aws-sdk/client-ecr": "^3.1003.0",
    "@aws-sdk/client-lambda": "^3.1003.0",
    "@aws-sdk/client-rds": "^3.1003.0",
    "@aws-sdk/client-resource-explorer-2": "^3.1003.0",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/client-sts": "^3.1003.0",
    "@cdktf/hcl2json": "^0.21.0",
    "@cloudburn/rules": "workspace:*",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "aws",
    "azure",
    "gcp",
    "cloud",
    "cost-optimization",
    "finops",
    "cloudburn",
    "terraform",
    "cloudformation",
    "iac",
    "scanner"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
