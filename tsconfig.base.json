{
  "compilerOptions": {
    "target": "ES2023",
    "baseUrl": ".",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "paths": {
      "@cloudburn/rules": ["packages/rules/src/index.ts"],
      "@cloudburn/sdk": ["packages/sdk/src/index.ts"]
    }
  }
}
