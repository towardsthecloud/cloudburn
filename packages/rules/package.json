{
  "name": "@cloudburn/rules",
  "version": "0.18.0",
  "description": "Cloudburn cost optimization rules",
  "homepage": "https://cloudburn.io/docs",
  "bugs": {
    "url": "https://github.com/towardsthecloud/cloudburn/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/towardsthecloud/cloudburn.git",
    "directory": "packages/rules"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "aws",
    "azure",
    "gcp",
    "cloud",
    "cost-optimization",
    "finops",
    "cloudburn",
    "terraform",
    "cloudformation",
    "iac"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
