{
  "name": "cloudburn",
  "version": "0.9.3",
  "description": "Cloudburn CLI for cloud cost optimization",
  "homepage": "https://cloudburn.io/docs",
  "bugs": {
    "url": "https://github.com/towardsthecloud/cloudburn/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/towardsthecloud/cloudburn.git",
    "directory": "packages/cloudburn"
  },
  "type": "module",
  "bin": {
    "cloudburn": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@cloudburn/sdk": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "aws",
    "azure",
    "gcp",
    "cloud",
    "cost-optimization",
    "finops",
    "cloudburn",
    "terraform",
    "cloudformation",
    "iac",
    "cli"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
